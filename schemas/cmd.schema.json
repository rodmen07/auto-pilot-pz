{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AutoPilot Command",
  "description": "Action command written by the Python sidecar to Zomboid/Lua/auto_pilot_cmd.json, read by AutoPilot_LLM.lua.",
  "type": "object",
  "required": ["action", "reason"],
  "additionalProperties": false,
  "properties": {
    "action": {
      "type": "string",
      "enum": ["eat", "drink", "sleep", "rest", "exercise", "outside", "fight", "flee", "bandage", "idle"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
